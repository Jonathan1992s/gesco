PUBLIC_GA4_ID=G-XXXXXXXXXX
PUBLIC_GTM_ID=GTM-XXXXXXX
PUBLIC_FORMSPREE_ID=xxxxxxxxxxx

# Envío de resultados del Test Vocacional CHASIDE.
# Configura una sola clave: RESEND_API_KEY o SENDGRID_API_KEY.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxx
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxx
EMAIL_DESTINO=orientacion@tudominio.com
EMAIL_REMITENTE=GESCO <no-reply@tudominio.com>

# Supabase — base de datos de resultados y verificación de certificados.
# Obtener en: supabase.com → proyecto → Settings → API
# Usar la clave service_role (nunca la anon key aquí — es server-side).
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxxx

# Firma HMAC para la API guardar-resultado.
# Generar con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Sin este valor la verificación de firma queda desactivada (útil en desarrollo).
API_SIGNING_SECRET=
