---
import { mobileActions } from '@/data/navigation';
---

<div class="fixed inset-x-0 bottom-0 z-40 grid grid-cols-2 border-t border-black/10 bg-white p-2 shadow-2xl lg:hidden">
  {mobileActions.map((item, index) => (
    <a
      href={item.href}
      target={index === 0 ? '_blank' : undefined}
      rel={index === 0 ? 'noopener noreferrer' : undefined}
      class={`solid-cta min-h-11 rounded-full px-4 py-3 text-center text-sm font-bold ${index === 0 ? 'bg-green-700 hover:bg-green-800' : 'bg-brand hover:bg-brand-dark'}`}
    >
      {item.label}
    </a>
  ))}
</div>
