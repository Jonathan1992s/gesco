---
import { WA } from '@/data/whatsapp';
import WhatsAppButton from '@/components/global/WhatsAppButton.astro';
---

<article class="container-g max-w-3xl py-10">
  <div class="prose prose-lg max-w-none prose-headings:font-heading prose-headings:text-navy prose-a:text-brand">
    <slot />
  </div>
  <div class="mt-10 rounded-3xl bg-surface p-6">
    <h2 class="text-2xl font-extrabold text-navy">¿Quieres una ruta de preparación?</h2>
    <p class="mt-2 text-muted">Un asesor de GESCO puede ayudarte a elegir el programa adecuado según tu universidad, ciudad y fecha de admisión.</p>
    <div class="mt-5">
      <WhatsAppButton href={WA.blog} label="Hablar con GESCO" source="article-body" />
    </div>
  </div>
</article>
