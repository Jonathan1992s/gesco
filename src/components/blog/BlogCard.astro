---
interface Props {
  title: string;
  description: string;
  href: string;
  category: string;
  readTime: string;
}

const { title, description, href, category, readTime } = Astro.props;
---

<article class="rounded-2xl border border-black/10 bg-white p-6 shadow-sm transition hover:-translate-y-1 hover:shadow-xl">
  <p class="text-sm font-bold uppercase tracking-wide text-brand">{category} · {readTime}</p>
  <h2 class="mt-3 text-2xl font-extrabold text-navy"><a href={href}>{title}</a></h2>
  <p class="mt-3 text-muted">{description}</p>
  <a href={href} class="mt-5 inline-block font-bold text-brand">Leer artículo →</a>
</article>
