---
import { testimonials } from '@/data/testimonials';
---

<section class="section-pad bg-surface">
  <div class="container-g">
    <div class="mx-auto max-w-3xl text-center">
      <p class="font-bold uppercase tracking-wide text-brand">Historias reales</p>
      <h2 class="mt-2 text-3xl font-extrabold text-navy md:text-4xl">Estudiantes que avanzaron con acompañamiento</h2>
    </div>
    <div class="mt-10 grid gap-6 md:grid-cols-2">
      {testimonials.map((item) => (
        <article class="rounded-2xl bg-white p-6 shadow-sm ring-1 ring-black/5">
          <div class="flex items-center gap-4">
            <img src={item.photo} alt={`${item.name}, estudiante GESCO`} width="96" height="96" loading="lazy" class="h-20 w-20 rounded-full object-cover" />
            <div>
              <h3 class="text-xl font-extrabold text-navy">{item.name}</h3>
              <p class="text-sm font-bold text-brand">{item.logro}</p>
            </div>
          </div>
          <p class="mt-5 text-muted">“{item.text}”</p>
          <p class="mt-4 text-accent" aria-label={`${item.stars} estrellas`}>★★★★★</p>
        </article>
      ))}
    </div>
  </div>
</section>
