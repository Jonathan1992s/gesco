---
import { BookOpenCheck, Compass, GraduationCap, Landmark } from '@lucide/astro';

const routes = [
  {
    Icon: Landmark,
    title: 'Para universidades públicas',
    copy: 'Prepárate para procesos de admisión con simuladores y clases.',
    cta: 'Ver ruta pública →',
    href: '/universidades-publicas/',
    visual: '/img/illustrations/ruta-publicas.svg',
    visualAlt: 'Ilustración de preparación para universidades públicas',
    tone: 'from-brand/10 to-brand/0 text-brand',
  },
  {
    Icon: GraduationCap,
    title: 'Para universidades privadas',
    copy: 'Entrena para pruebas internas, inglés y procesos propios.',
    cta: 'Ver ruta privada →',
    href: '/universidades-privadas/',
    visual: '/img/illustrations/ruta-privadas.svg',
    visualAlt: 'Ilustración de entrenamiento para pruebas universitarias privadas',
    tone: 'from-accent/20 to-accent/0 text-navy',
  },
  {
    Icon: BookOpenCheck,
    title: 'Necesito mejorar mis notas',
    copy: 'Refuerzos para recuperar bases y avanzar con confianza.',
    cta: 'Pedir ayuda →',
    href: '/refuerzo-academico/',
    visual: '/img/illustrations/ruta-refuerzos.svg',
    visualAlt: 'Ilustración de estudiante repasando materias',
    tone: 'from-success/10 to-success/0 text-success',
  },
  {
    Icon: Compass,
    title: 'No sé qué carrera elegir',
    copy: 'Descubre tu perfil y la carrera que mejor encaja contigo.',
    cta: 'Hacer test →',
    href: '/test-vocacional/',
    visual: '/img/illustrations/ruta-vocacional.svg',
    visualAlt: 'Ilustración de orientación vocacional y elección de carrera',
    tone: 'from-navy/10 to-navy/0 text-navy',
  },
];
---

<section class="section-pad bg-white">
  <div class="container-g">
    <div class="max-w-2xl">
      <p class="font-bold uppercase tracking-wide text-brand">Elige tu ruta</p>
      <h2 class="mt-2 text-3xl font-extrabold text-navy md:text-4xl">Cada estudiante necesita una preparación distinta</h2>
    </div>
    <div class="mt-10 grid gap-5 md:grid-cols-2 lg:grid-cols-4">
      {routes.map((route) => (
        <a href={route.href} class={`group overflow-hidden rounded-3xl border border-black/10 bg-gradient-to-br ${route.tone} shadow-sm transition hover:-translate-y-1 hover:border-brand/30 hover:shadow-xl`}>
          <div class="relative flex h-36 items-center justify-center overflow-hidden bg-white/70 p-5">
            <img
              src={route.visual}
              alt={route.visualAlt}
              width="220"
              height="150"
              loading="lazy"
              class="h-full w-full object-contain transition duration-300 group-hover:scale-105"
            />
            <span class="absolute left-5 top-5 inline-flex h-12 w-12 items-center justify-center rounded-2xl bg-white text-brand shadow-md ring-1 ring-black/5" aria-hidden="true">
              <route.Icon class="h-6 w-6" stroke-width={2.35} />
            </span>
          </div>
          <div class="p-6">
          <h3 class="text-xl font-extrabold text-navy">{route.title}</h3>
          <p class="mt-3 text-muted">{route.copy}</p>
          <span class="mt-5 inline-flex items-center font-bold text-brand group-hover:text-brand-dark">{route.cta}</span>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
