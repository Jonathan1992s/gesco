---
import { WA } from '@/data/whatsapp';
import WhatsAppButton from '@/components/global/WhatsAppButton.astro';

const chips = ['Simuladores', 'Clases online en vivo', 'Orientación vocacional', 'Refuerzos'];
---

<section class="relative isolate overflow-hidden bg-navy text-white">
  <img
    src="/img/header-bg.webp"
    alt="Estudiantes preparándose online para ingresar a la universidad con GESCO"
    width="1600"
    height="900"
    fetchpriority="high"
    class="absolute inset-0 -z-20 h-full w-full object-cover opacity-45"
  />
  <div class="absolute inset-0 -z-10 bg-gradient-to-r from-navy via-navy/80 to-brand/55"></div>

  <div class="container-g grid min-h-[680px] items-center py-16 md:min-h-[720px]">
    <div class="max-w-3xl">
      <p class="hero-animate mb-5 inline-flex rounded-full bg-white/12 px-4 py-2 text-sm font-bold text-accent ring-1 ring-white/20">
        Preuniversitario online · Clases para todo Ecuador
      </p>
      <h1 class="hero-animate text-4xl font-extrabold leading-tight md:text-6xl" style="animation-delay: 0.1s">
        Preuniversitario Online en Ecuador para el Ingreso Universitario
      </h1>
      <p class="hero-animate mt-6 max-w-2xl text-lg text-white/85 md:text-xl" style="animation-delay: 0.2s">
        En GESCO te acompañamos con clases online en vivo, Plataforma Gesco, simuladores, orientación vocacional y refuerzos académicos para que llegues con mayor seguridad a tu proceso de admisión. Nuestra sede está en Quito y atendemos a estudiantes de todo Ecuador.
      </p>
      <div class="hero-animate mt-8 flex flex-col gap-3 sm:flex-row" style="animation-delay: 0.3s">
        <WhatsAppButton href={WA.home} label="Quiero prepararme para la U" source="hero-home" />
        <WhatsAppButton href={WA.padres} label="Soy padre/madre" source="hero-padres" variant="ghost" />
      </div>
      <p class="hero-animate mt-5 text-sm font-semibold text-white/75" style="animation-delay: 0.4s">
        +10 años de experiencia · +10.000 estudiantes preparados · Atención por WhatsApp
      </p>
      <div class="hero-animate mt-8 flex flex-wrap gap-3" style="animation-delay: 0.5s">
        {chips.map((chip) => (
          <span class="rounded-full bg-white px-4 py-2 text-sm font-bold text-navy shadow-lg">{chip}</span>
        ))}
      </div>
    </div>
  </div>
</section>
