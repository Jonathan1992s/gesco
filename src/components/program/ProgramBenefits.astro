---
interface Props {
  items: string[];
}

const { items } = Astro.props;

const benefitDescriptions: Record<string, string> = {
  'Análisis de perfil': 'Identificamos intereses, fortalezas y áreas vocacionales para orientar mejor la decisión.',
  'Resultados explicados': 'El estudiante recibe una lectura clara de sus puntajes y áreas principales.',
  'Orientación profesional online': 'Acompañamiento remoto para transformar el resultado en opciones reales de carrera.',
  'Modalidad online': 'Proceso flexible para estudiantes de cualquier ciudad de Ecuador.',
};

const fallbackDescriptions = [
  'Acompañamiento pensado para avanzar con una ruta clara.',
  'Herramientas prácticas para tomar mejores decisiones.',
  'Seguimiento académico y orientación según el objetivo.',
  'Experiencia online flexible y fácil de seguir.',
];
---

<section class="section-pad bg-white">
  <div class="container-g">
    <div class="max-w-2xl">
      <p class="font-bold uppercase tracking-wide text-brand">Acompañamiento GESCO</p>
      <h2 class="mt-2 text-3xl font-extrabold text-navy md:text-4xl">Qué incluye esta ruta</h2>
      <p class="mt-4 text-muted">Un proceso claro para entender el perfil del estudiante y convertir el resultado en decisiones académicas concretas.</p>
    </div>

    <div class="mt-8 grid gap-4 md:grid-cols-2 lg:grid-cols-4">
      {items.map((item, index) => (
        <article class="group rounded-2xl border border-black/10 bg-white p-5 shadow-sm transition hover:-translate-y-1 hover:border-brand/30 hover:shadow-lg">
          <span class="grid h-11 w-11 place-items-center rounded-2xl bg-brand/10 text-lg font-extrabold text-brand ring-1 ring-brand/15" aria-hidden="true">
            {index + 1}
          </span>
          <h3 class="mt-4 text-lg font-extrabold text-navy">{item}</h3>
          <p class="mt-2 text-sm text-muted">{benefitDescriptions[item] ?? fallbackDescriptions[index % fallbackDescriptions.length]}</p>
        </article>
      ))}
    </div>
  </div>
</section>
