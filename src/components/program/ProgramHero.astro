---
import { WA } from '@/data/whatsapp';
import type { Program } from '@/data/programs';
import WhatsAppButton from '@/components/global/WhatsAppButton.astro';

interface Props {
  program: Program;
}

const { program } = Astro.props;
---

<section class="bg-surface py-12 md:py-16">
  <div class="container-g grid items-center gap-10 lg:grid-cols-2">
    <div>
      <p class="font-bold uppercase tracking-wide text-brand">{program.eyebrow}</p>
      <h1 class="mt-3 text-4xl font-extrabold leading-tight text-navy md:text-5xl">{program.title}</h1>
      <p class="mt-5 text-lg text-muted">{program.description}</p>
      <p class="mt-4 font-semibold text-navy">{program.audience}</p>
      <div class="mt-7">
        <WhatsAppButton href={WA[program.waKey]} label="Solicitar información" source={`program-${program.slug}`} />
      </div>
    </div>
    <div class="flex min-h-80 items-center justify-center overflow-hidden rounded-3xl bg-gradient-to-br from-brand/10 via-white to-accent/10 p-8 shadow-xl">
      <img src={program.image} alt={program.imageAlt} width="720" height="520" loading="eager" class="max-h-96 w-full object-contain" />
    </div>
  </div>
</section>
