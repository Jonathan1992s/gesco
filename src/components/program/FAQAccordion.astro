---
import type { FaqItem } from '@/data/faqs';

interface Props {
  items: FaqItem[];
}

const { items } = Astro.props;
---

<section class="section-pad bg-white">
  <div class="container-g max-w-3xl">
    <h2 class="text-3xl font-extrabold text-navy md:text-4xl">Preguntas frecuentes</h2>
    <div class="mt-8 grid gap-3">
      {items.map((item) => (
        <details class="rounded-2xl border border-black/10 bg-white p-5">
          <summary class="cursor-pointer font-bold text-navy">{item.q}</summary>
          <p class="mt-3 text-muted">{item.a}</p>
        </details>
      ))}
    </div>
  </div>
</section>
