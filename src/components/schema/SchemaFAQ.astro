---
import type { FaqItem } from '@/data/faqs';

interface Props {
  items: FaqItem[];
}

const { items } = Astro.props;
const schema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: items.map((item) => ({
    '@type': 'Question',
    name: item.q,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.a,
    },
  })),
};
---

<script is:inline type="application/ld+json" set:html={JSON.stringify(schema)} />
