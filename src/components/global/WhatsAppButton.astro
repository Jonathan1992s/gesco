---
interface Props {
  href: string;
  label?: string;
  source?: string;
  variant?: 'primary' | 'secondary' | 'ghost';
  labelClass?: string;
  class?: string;
}

const {
  href,
  label = 'Escribir por WhatsApp',
  source,
  variant = 'primary',
  labelClass = '',
  class: extraClass = '',
} = Astro.props;

const variants = {
  primary: 'solid-cta bg-green-700 hover:bg-green-800',
  secondary: 'bg-white text-navy hover:bg-surface',
  ghost: 'border border-white/70 text-white! hover:bg-white/10',
};
---

<a
  href={href}
  target="_blank"
  rel="noopener noreferrer"
  data-wa-source={source}
  style={variant === 'primary' || variant === 'ghost' ? 'color: #ffffff;' : undefined}
  class={`inline-flex min-h-11 items-center justify-center gap-2 rounded-full px-5 py-3 text-sm font-semibold transition ${variants[variant]} ${extraClass}`}
>
  <svg aria-hidden="true" viewBox="0 0 32 32" class="h-5 w-5 fill-current">
    <path d="M16.01 3.2A12.68 12.68 0 0 0 5.2 22.52L3.8 28.8l6.42-1.35A12.7 12.7 0 1 0 16.01 3.2Zm0 22.96a10.29 10.29 0 0 1-5.24-1.43l-.38-.23-3.8.8.81-3.7-.25-.39a10.28 10.28 0 1 1 8.86 4.95Zm5.7-7.7c-.31-.16-1.84-.91-2.13-1.01-.29-.11-.5-.16-.71.16-.21.31-.81 1-.99 1.21-.18.21-.36.24-.67.08-.31-.16-1.31-.48-2.49-1.54-.92-.82-1.54-1.83-1.72-2.14-.18-.31-.02-.48.14-.63.14-.14.31-.36.47-.54.16-.18.21-.31.31-.52.1-.21.05-.39-.03-.55-.08-.16-.71-1.71-.97-2.34-.25-.61-.52-.53-.71-.54h-.6c-.21 0-.55.08-.84.39-.29.31-1.1 1.08-1.1 2.63s1.13 3.05 1.29 3.26c.16.21 2.23 3.4 5.4 4.77.75.32 1.34.52 1.8.66.76.24 1.45.21 1.99.13.61-.09 1.84-.75 2.1-1.48.26-.73.26-1.35.18-1.48-.08-.13-.29-.21-.6-.37Z" />
  </svg>
  <span class={labelClass}>{label}</span>
</a>
