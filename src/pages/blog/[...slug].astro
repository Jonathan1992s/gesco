---
import { getCollection, render } from 'astro:content';
import BlogLayout from '@/layouts/BlogLayout.astro';
import ArticleBody from '@/components/blog/ArticleBody.astro';
import ShareButtons from '@/components/global/ShareButtons.astro';
import { SITE } from '@/data/site';
import { articleSchema, breadcrumbSchema, faqSchema } from '@/data/schema';
import type { FaqItem } from '@/data/faqs';

const cleanMarkdown = (value: string) =>
  value
    .replace(/\*\*(.*?)\*\*/g, '$1')
    .replace(/\[(.*?)\]\((.*?)\)/g, '$1')
    .replace(/`([^`]+)`/g, '$1')
    .replace(/<[^>]+>/g, '')
    .replace(/\s+/g, ' ')
    .trim();

const extractFaqsFromBody = (body: string): FaqItem[] => {
  const faqStart = body.search(/^##\s+Preguntas frecuentes\s*$/m);
  if (faqStart === -1) return [];

  const faqBlock = body.slice(faqStart).replace(/^##\s+Preguntas frecuentes\s*$/m, '');
  const matches = [...faqBlock.matchAll(/^###\s+(.+?)\s*\n([\s\S]*?)(?=^###\s+|^##\s+|$)/gm)];

  return matches
    .map((match) => ({
      q: cleanMarkdown(match[1]),
      a: cleanMarkdown(match[2]),
    }))
    .filter((item) => item.q && item.a);
};

const posts = await getCollection('blog');
const entry = posts.find((p) => p.id.replace(/\.mdx$/, '') === Astro.params.slug);
if (!entry) return Astro.redirect('/404');
const { Content } = await render(entry);
const slug = entry.id.replace(/\.mdx$/, '');
const canonical = `${SITE.url}/blog/${slug}/`;
const articleFaqs = extractFaqsFromBody(entry.body ?? '');
const schema = [
  articleSchema({
    title: entry.data.title,
    description: entry.data.description,
    canonical,
    datePublished: entry.data.pubDate,
    dateModified: entry.data.updatedDate,
  }),
  ...(articleFaqs.length ? [faqSchema(articleFaqs)] : []),
  breadcrumbSchema([
    { label: 'Inicio', href: '/' },
    { label: 'Blog', href: '/blog/' },
    { label: entry.data.title, href: `/blog/${slug}/` },
  ]),
];
---

<BlogLayout
  title={entry.data.seoTitle ?? entry.data.title}
  description={entry.data.description}
  canonical={canonical}
  pageName={entry.data.title}
  schema={schema}
>
  <section class="bg-surface py-12 md:py-16">
    <div class="container-g max-w-3xl">
      <p class="font-bold uppercase tracking-wide text-brand">{entry.data.category} · {entry.data.readTime}</p>
      <h1 class="mt-3 text-4xl font-extrabold text-navy md:text-5xl">{entry.data.title}</h1>
      <p class="mt-5 text-lg text-muted">{entry.data.description}</p>
    </div>
  </section>
  <ArticleBody>
    <Content />
  </ArticleBody>
  <div class="border-t border-black/8 bg-white py-6">
    <div class="container-g max-w-3xl">
      <ShareButtons url={canonical} title={entry.data.title} />
    </div>
  </div>
</BlogLayout>
