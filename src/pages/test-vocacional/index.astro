---
import { createHmac } from 'node:crypto';
import ProgramLayout from '@/layouts/ProgramLayout.astro';
import ProgramHero from '@/components/program/ProgramHero.astro';
import ProgramBenefits from '@/components/program/ProgramBenefits.astro';
import CurriculumGrid from '@/components/program/CurriculumGrid.astro';
import FAQAccordion from '@/components/program/FAQAccordion.astro';
import ProgramCTA from '@/components/program/ProgramCTA.astro';
import ChasideTest from '@/components/interactive/ChasideTest';
import { SITE, seoByPath } from '@/data/site';
import { getProgram } from '@/data/programs';
import { programFaqs } from '@/data/faqs';
import { breadcrumbSchema, courseSchema, faqSchema } from '@/data/schema';

const signingSecret = import.meta.env.API_SIGNING_SECRET ?? '';
const ts = Math.floor(Date.now() / 1000);
const apiToken = signingSecret
  ? `${ts}.${createHmac('sha256', signingSecret).update(String(ts)).digest('hex')}`
  : '';

const program = getProgram('test-vocacional');
if (!program) throw new Error('Programa test-vocacional no encontrado');
const seo = seoByPath['/test-vocacional/'];
const canonical = `${SITE.url}/test-vocacional/`;
const faqs = programFaqs.vocacional;
const chasideFaqs = [
  {
    q: '¿Qué es el test vocacional CHASIDE?',
    a:
      'El test CHASIDE es una herramienta orientativa que cruza intereses y aptitudes para sugerir áreas profesionales compatibles. Sirve como punto de partida para conversar sobre carreras, universidades y decisiones académicas.',
  },
  {
    q: '¿El resultado del test CHASIDE define mi carrera?',
    a:
      'No. El resultado no es un diagnóstico psicológico definitivo. Debe interpretarse como una guía inicial y puede complementarse con orientación vocacional, revisión de materias favoritas, habilidades, contexto familiar y opciones universitarias.',
  },
  {
    q: '¿Cuánto tiempo toma responder el test vocacional?',
    a:
      'El simulador tiene 98 preguntas de Sí o No. La mayoría de estudiantes lo completa entre 10 y 15 minutos si responde con sinceridad y sin sobrepensar cada pregunta.',
  },
  {
    q: '¿Qué recibo al finalizar el simulador CHASIDE?',
    a:
      'Recibes puntajes por intereses, aptitudes y total por área, tus dos áreas principales, una descripción de cada perfil y carreras sugeridas relacionadas.',
  },
];
const schema = [
  courseSchema(program.name, program.description, { courseMode: 'online' }),
  faqSchema([...chasideFaqs, ...faqs]),
  breadcrumbSchema([{ label: 'Inicio', href: '/' }, { label: program.name, href: '/test-vocacional/' }]),
];
---

<ProgramLayout title={seo.title} description={seo.description} canonical={canonical} pageName={program.name} schema={schema}>
  <ProgramHero program={program} />

  <section class="section-pad bg-white">
    <div class="container-g grid gap-10 lg:grid-cols-[0.95fr_1.05fr] lg:items-center">
      <div>
        <p class="font-bold uppercase tracking-wide text-brand">Test vocacional online</p>
        <h2 class="mt-3 text-3xl font-extrabold text-navy md:text-4xl">Elige carrera con una lectura más clara de tus intereses</h2>
        <p class="mt-4 text-muted">
          El simulador CHASIDE de GESCO ayuda a estudiantes de bachillerato y aspirantes universitarios a identificar áreas profesionales relacionadas con sus gustos, habilidades y forma de resolver problemas.
        </p>
        <p class="mt-4 text-muted">
          Al finalizar puedes descargar, imprimir o enviar tus resultados para recibir orientación académica sobre carreras, universidades y preparación preuniversitaria.
        </p>
      </div>
      <div class="grid gap-4 sm:grid-cols-2">
        {[
          ['98 preguntas', 'Formato rápido de Sí o No para medir intereses y aptitudes.'],
          ['7 áreas CHASIDE', 'Administrativas, humanísticas, artísticas, salud, ingeniería, defensa y exactas.'],
          ['Reporte inmediato', 'Puntajes, gráfico, dos áreas principales y carreras sugeridas.'],
          ['Seguimiento GESCO', 'El resultado puede convertirse en una ruta de orientación y preparación.'],
        ].map(([title, text]) => (
          <article class="rounded-2xl border border-black/10 bg-surface p-5">
            <h3 class="text-lg font-extrabold text-navy">{title}</h3>
            <p class="mt-2 text-sm text-muted">{text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section-pad bg-surface">
    <div class="container-g">
      <div class="mx-auto max-w-3xl text-center">
        <p class="font-bold uppercase tracking-wide text-brand">Cómo funciona</p>
        <h2 class="mt-3 text-3xl font-extrabold text-navy md:text-4xl">Instrucciones para responder el test CHASIDE</h2>
      </div>
      <div class="mt-10 grid gap-5 md:grid-cols-3">
        {[
          ['1. Responde con sinceridad', 'No hay respuestas buenas o malas. Marca Sí cuando la frase te representa y No cuando no coincide contigo.'],
          ['2. Completa todas las preguntas', 'El resultado solo se calcula cuando las 98 preguntas están respondidas, porque cada área combina intereses y aptitudes.'],
          ['3. Deja tus datos al final', 'Pedimos tu información al terminar para generar el reporte y facilitar el envío de resultados o asesoría académica.'],
        ].map(([title, text]) => (
          <article class="rounded-2xl bg-white p-6 shadow-sm ring-1 ring-black/5">
            <h3 class="text-xl font-extrabold text-navy">{title}</h3>
            <p class="mt-3 text-muted">{text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <ChasideTest client:visible apiToken={apiToken} />

  <section class="section-pad bg-white">
    <div class="container-g grid gap-8 lg:grid-cols-[0.9fr_1.1fr] lg:items-start">
      <div>
        <p class="font-bold uppercase tracking-wide text-brand">Interpretación</p>
        <h2 class="mt-3 text-3xl font-extrabold text-navy md:text-4xl">¿Qué mide el test CHASIDE?</h2>
        <p class="mt-4 text-muted">
          CHASIDE organiza las respuestas en siete áreas vocacionales. Cada área recibe puntajes de intereses y aptitudes para mostrar afinidad con familias de carreras.
        </p>
        <p class="mt-4 text-muted">
          La lectura más útil aparece cuando combinas el resultado con tu rendimiento académico, materias favoritas, estilo de aprendizaje y objetivos profesionales.
        </p>
      </div>
      <div class="grid gap-3">
        {[
          ['C', 'Administrativas y Contables'],
          ['H', 'Humanísticas y Sociales'],
          ['A', 'Artísticas'],
          ['S', 'Medicina y Ciencias de la Salud'],
          ['I', 'Ingeniería y Computación'],
          ['D', 'Defensa y Seguridad'],
          ['E', 'Ciencias Exactas y Agrarias'],
        ].map(([code, name]) => (
          <div class="flex items-center gap-4 rounded-2xl border border-black/10 p-4">
            <span class="grid h-11 w-11 place-items-center rounded-full bg-brand font-extrabold text-white">{code}</span>
            <p class="font-bold text-navy">{name}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <ProgramBenefits items={program.benefits} />
  <CurriculumGrid items={program.curriculum} />

  <section class="section-pad bg-surface" id="chaside-faq">
    <div class="container-g">
      <div class="mx-auto max-w-3xl text-center">
        <p class="font-bold uppercase tracking-wide text-brand">Preguntas frecuentes</p>
        <h2 class="mt-3 text-3xl font-extrabold text-navy md:text-4xl">Dudas comunes sobre el test vocacional CHASIDE</h2>
      </div>
      <div class="mx-auto mt-10 grid max-w-3xl gap-3">
        {chasideFaqs.map((item) => (
          <details class="rounded-2xl border border-black/10 bg-white p-5">
            <summary class="cursor-pointer font-bold text-navy">{item.q}</summary>
            <p class="mt-3 text-muted">{item.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <FAQAccordion items={faqs} />
  <ProgramCTA waKey={program.waKey} source="vocacional-final" />
</ProgramLayout>
