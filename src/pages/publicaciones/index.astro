---
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { SITE, seoByPath } from '@/data/site';
import { breadcrumbSchema } from '@/data/schema';

const seo = seoByPath['/publicaciones/'];
const canonical = `${SITE.url}/publicaciones/`;
const schema = breadcrumbSchema([
  { label: 'Inicio', href: '/' },
  { label: 'Publicaciones', href: '/publicaciones/' },
]);

const revistas = (await getCollection('publicaciones')).sort(
  (a, b) => b.data.numero - a.data.numero,
);

const years = [...new Set(revistas.map((r) => r.data.year))].sort((a, b) => b - a);
const featured = revistas.slice(0, 2);
const archive = revistas.slice(2);

const autoresParlamentarios = [
  ...new Set(
    revistas
      .filter((r) => r.data.autorParlamentario)
      .flatMap((r) => r.data.autorParlamentario!.split(' / ').map((a) => a.trim())),
  ),
].sort((a, b) => a.split(' ').slice(-1)[0].localeCompare(b.split(' ').slice(-1)[0]));
---

<BaseLayout title={seo.title} description={seo.description} canonical={canonical} schema={schema}>

  <!-- ── HERO ─────────────────────────────────────────────────── -->
  <section class="relative overflow-hidden bg-navy py-20 md:py-28">
    <span aria-hidden="true"
      class="pointer-events-none absolute -right-8 -top-6 select-none font-black text-white/[0.04] text-[22rem] leading-none tracking-tighter">
      NJ
    </span>
    <div class="container-g relative">
      <p class="text-xs font-bold uppercase tracking-[0.2em] text-brand">Corporación para la Gestión del Conocimiento</p>
      <h1 class="mt-3 text-5xl font-extrabold leading-tight text-white md:text-6xl">
        Revista<br class="hidden sm:block" /> Nueva<br class="hidden sm:block" /> Jurisprudencia
      </h1>
      <p class="mt-5 max-w-lg text-base text-white/55">
        Análisis jurídico, doctrina y actualidad legal del Ecuador. Publicación mensual de referencia para profesionales del derecho.
      </p>
      <div class="mt-10 flex flex-wrap gap-8">
        <div>
          <p class="text-3xl font-extrabold text-white">{revistas.length}</p>
          <p class="text-xs text-white/40 uppercase tracking-wider mt-0.5">Ediciones</p>
        </div>
        <div>
          <p class="text-3xl font-extrabold text-white">{years.length}</p>
          <p class="text-xs text-white/40 uppercase tracking-wider mt-0.5">Años</p>
        </div>
        <div>
          <p class="text-3xl font-extrabold text-white">NJ {revistas[0].data.numero}</p>
          <p class="text-xs text-white/40 uppercase tracking-wider mt-0.5">Última edición</p>
        </div>
        <div>
          <p class="text-3xl font-extrabold text-white">{autoresParlamentarios.length}</p>
          <p class="text-xs text-white/40 uppercase tracking-wider mt-0.5">Expertos</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ── FILTROS ────────────────────────────────────────────────── -->
  <div class="sticky top-[79px] z-40 border-b border-black/8 bg-white/95 backdrop-blur">
    <div class="container-g flex flex-wrap items-center gap-x-6 gap-y-2 py-3">

      <!-- Filtro por año (pills) -->
      <div class="flex items-center gap-2 shrink-0">
        <span class="text-[10px] font-bold uppercase tracking-wider text-muted">Año</span>
        <button data-year="all" class="year-btn rounded-full bg-navy px-3.5 py-1.5 text-xs font-bold text-white transition-all">Todas</button>
        {years.map((y) => (
          <button data-year={String(y)} class="year-btn rounded-full border border-black/12 px-3.5 py-1.5 text-xs font-bold text-navy transition-all hover:bg-surface">{y}</button>
        ))}
      </div>

      <!-- Combobox por autor -->
      <div class="relative flex-1 min-w-[200px] max-w-xs" id="autor-combobox">
        <span class="text-[10px] font-bold uppercase tracking-wider text-muted sr-only">Autor</span>
        <div class="relative">
          <svg class="pointer-events-none absolute left-3 top-1/2 -translate-y-1/2 h-3.5 w-3.5 text-muted" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
            <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
          </svg>
          <input
            id="autor-input"
            type="text"
            placeholder="Filtrar por autor experto..."
            autocomplete="off"
            spellcheck="false"
            class="w-full rounded-full border border-black/12 bg-white py-1.5 pl-8 pr-8 text-xs font-medium text-navy placeholder:text-muted/60 outline-none focus:border-brand focus:ring-1 focus:ring-brand/30 transition-all"
          />
          <button
            id="autor-clear"
            type="button"
            aria-label="Limpiar filtro de autor"
            class="absolute right-2.5 top-1/2 -translate-y-1/2 hidden h-4 w-4 items-center justify-center rounded-full bg-black/10 text-navy hover:bg-black/20 transition-colors"
          >
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" class="h-2.5 w-2.5" aria-hidden="true">
              <path d="M18 6 6 18M6 6l12 12"/>
            </svg>
          </button>
        </div>
        <ul
          id="autor-dropdown"
          role="listbox"
          aria-label="Autores disponibles"
          class="absolute left-0 right-0 top-full mt-1 hidden max-h-60 overflow-y-auto rounded-xl border border-black/10 bg-white py-1 shadow-xl shadow-black/10 z-50"
        >
          {autoresParlamentarios.map((a) => (
            <li
              role="option"
              aria-selected="false"
              data-autor-value={a}
              class="autor-option cursor-pointer px-4 py-2 text-xs font-medium text-navy hover:bg-brand/8 hover:text-brand transition-colors"
            >
              {a}
            </li>
          ))}
        </ul>
      </div>

    </div>
  </div>

  <!-- ── VISTA NORMAL (sin filtro de autor) ─────────────────────── -->
  <div id="section-normal">

    <!-- Featured (últimas 2) -->
    <section class="bg-white pt-10 pb-4">
      <div class="container-g">
        <p class="mb-5 text-xs font-bold uppercase tracking-[0.18em] text-muted">Últimas ediciones</p>
        <div class="grid gap-5 sm:grid-cols-2">
          {featured.map((r) => {
            const slug = r.id.replace(/\.mdx$/, '');
            return (
              <article
                data-year={r.data.year}
                data-autor={r.data.autorParlamentario ?? ''}
                data-card-normal
                class="card-reveal group relative flex min-h-[300px] flex-col overflow-hidden rounded-2xl bg-navy p-7 ring-1 ring-white/8 transition-all duration-300 hover:-translate-y-1 hover:ring-brand/40 hover:shadow-2xl hover:shadow-brand/15"
              >
                <span aria-hidden="true"
                  class="pointer-events-none absolute -bottom-6 -right-3 select-none font-black text-white/[0.06] text-[10rem] leading-none">
                  {r.data.numero}
                </span>
                <div class="relative flex items-start justify-between gap-3">
                  <span class="inline-flex items-center gap-1.5 rounded-full bg-brand/20 px-3 py-1 text-xs font-extrabold tracking-wide text-brand">
                    N.° {r.data.numero}
                  </span>
                  <span class="text-xs font-medium text-white/40">{r.data.mes} {r.data.year}</span>
                </div>
                <div class="relative mt-auto pt-8">
                  <p class="text-[10px] font-bold uppercase tracking-widest text-brand/70 mb-2">Derecho Parlamentario</p>
                  <h2 class="text-xl font-bold leading-snug text-white">{r.data.analisisParlamentario}</h2>
                  <p class="mt-1 text-xs text-white/50">— {r.data.autorParlamentario}</p>
                </div>
                <div class="relative mt-4 flex flex-wrap gap-1.5">
                  {r.data.temas.map((t: string) => (
                    <span class="rounded-md bg-white/[0.07] px-2.5 py-1 text-[11px] font-medium text-white/55">{t}</span>
                  ))}
                </div>
                <div class="relative mt-5 flex">
                  <a href={`/publicaciones/${slug}/`}
                    class="solid-cta inline-flex items-center gap-2 rounded-full bg-brand px-4 py-2 text-sm font-bold text-white transition-all duration-200 hover:bg-brand-dark"
                    aria-label={`Leer edición NJ ${r.data.numero}`}>
                    <svg aria-hidden="true" class="h-3.5 w-3.5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                      <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>
                    </svg>
                    <span class="hidden sm:inline">Leer edición</span>
                  </a>
                </div>
              </article>
            );
          })}
        </div>
      </div>
    </section>

    <!-- Archivo -->
    <section class="bg-white pt-4 pb-20">
      <div class="container-g">
        <p class="mb-5 text-xs font-bold uppercase tracking-[0.18em] text-muted">Archivo</p>
        <div class="grid gap-4 grid-cols-2 sm:grid-cols-3 lg:grid-cols-4">
          {archive.map((r) => {
            const slug = r.id.replace(/\.mdx$/, '');
            return (
              <article
                data-year={r.data.year}
                data-autor={r.data.autorParlamentario ?? ''}
                data-card-normal
                class="card-reveal group relative flex flex-col overflow-hidden rounded-xl bg-navy p-5 ring-1 ring-white/8 transition-all duration-300 hover:-translate-y-1 hover:ring-brand/40 hover:shadow-xl hover:shadow-brand/10"
              >
                <span aria-hidden="true"
                  class="pointer-events-none absolute -bottom-4 -right-1 select-none font-black text-white/[0.06] text-[5.5rem] leading-none">
                  {r.data.numero}
                </span>
                <div class="relative">
                  <span class="text-[10px] font-extrabold tracking-widest text-brand">N.° {r.data.numero}</span>
                  <p class="text-[10px] text-white/40 mt-0.5">{r.data.mes} {r.data.year}</p>
                </div>
                <h2 class="relative mt-3 text-sm font-bold leading-snug text-white line-clamp-2 flex-1">
                  {r.data.analisisParlamentario}
                </h2>
                <p class="relative mt-1 text-[10px] text-white/35">— {r.data.autorParlamentario}</p>
                <div class="relative mt-3 flex flex-wrap gap-1">
                  {r.data.temas.slice(0, 2).map((t: string) => (
                    <span class="rounded bg-white/[0.07] px-2 py-0.5 text-[10px] text-white/50">{t}</span>
                  ))}
                </div>
                <div class="relative mt-4 flex">
                  <a href={`/publicaciones/${slug}/`}
                    class="solid-cta inline-flex items-center gap-2 rounded-full bg-brand px-4 py-2 text-sm font-bold text-white transition-all duration-200 hover:bg-brand-dark"
                    aria-label={`Leer edición NJ ${r.data.numero}`}>
                    <svg aria-hidden="true" class="h-3.5 w-3.5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                      <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>
                    </svg>
                    <span class="hidden sm:inline">Leer edición</span>
                  </a>
                </div>
              </article>
            );
          })}
        </div>
      </div>
    </section>

  </div>

  <!-- ── VISTA FILTRADA (con filtro de autor activo) ─────────────── -->
  <div id="section-filtered" class="hidden bg-white py-10 pb-20">
    <div class="container-g">
      <p id="filtered-label" class="mb-5 text-xs font-bold uppercase tracking-[0.18em] text-muted">Resultados</p>
      <div class="grid gap-5 sm:grid-cols-2">
        {revistas.map((r) => {
          const slug = r.id.replace(/\.mdx$/, '');
          return (
            <article
              data-year={r.data.year}
              data-autor={r.data.autorParlamentario ?? ''}
              data-card-filtered
              class="card-reveal group relative flex min-h-[300px] flex-col overflow-hidden rounded-2xl bg-navy p-7 ring-1 ring-white/8 transition-all duration-300 hover:-translate-y-1 hover:ring-brand/40 hover:shadow-2xl hover:shadow-brand/15"
            >
              <span aria-hidden="true"
                class="pointer-events-none absolute -bottom-6 -right-3 select-none font-black text-white/[0.06] text-[10rem] leading-none">
                {r.data.numero}
              </span>
              <div class="relative flex items-start justify-between gap-3">
                <span class="inline-flex items-center gap-1.5 rounded-full bg-brand/20 px-3 py-1 text-xs font-extrabold tracking-wide text-brand">
                  N.° {r.data.numero}
                </span>
                <span class="text-xs font-medium text-white/40">{r.data.mes} {r.data.year}</span>
              </div>
              <div class="relative mt-auto pt-8">
                <p class="text-[10px] font-bold uppercase tracking-widest text-brand/70 mb-2">Derecho Parlamentario</p>
                <h2 class="text-xl font-bold leading-snug text-white">{r.data.analisisParlamentario}</h2>
                <p class="mt-1 text-xs text-white/50">— {r.data.autorParlamentario}</p>
              </div>
              <div class="relative mt-4 flex flex-wrap gap-1.5">
                {r.data.temas.map((t: string) => (
                  <span class="rounded-md bg-white/[0.07] px-2.5 py-1 text-[11px] font-medium text-white/55">{t}</span>
                ))}
              </div>
              <div class="relative mt-5 flex">
                <a href={`/publicaciones/${slug}/`}
                  class="solid-cta inline-flex items-center gap-2 rounded-full bg-brand px-4 py-2 text-sm font-bold text-white transition-all duration-200 hover:bg-brand-dark"
                  aria-label={`Leer edición NJ ${r.data.numero}`}>
                  <svg aria-hidden="true" class="h-3.5 w-3.5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                    <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>
                  </svg>
                  <span class="hidden sm:inline">Leer edición</span>
                </a>
              </div>
            </article>
          );
        })}
      </div>
    </div>
  </div>

</BaseLayout>

<style>
  .card-reveal {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.4s ease, transform 0.4s ease, box-shadow 0.3s ease, translate 0.3s ease;
  }
  .card-reveal.visible { opacity: 1; transform: translateY(0); }
  .autor-option[aria-selected="true"] { background-color: rgb(27 136 226 / 0.1); color: #1b88e2; font-weight: 700; }
</style>

<script>
  function initPublicaciones() {
    // ── Reveal cards on scroll ──────────────────────────────────
    const observer = new IntersectionObserver(
      (entries) => entries.forEach((e) => {
        if (e.isIntersecting) {
          (e.target as HTMLElement).classList.add('visible');
          observer.unobserve(e.target);
        }
      }),
      { threshold: 0.05, rootMargin: '0px 0px 100px 0px' },
    );
    const observeCards = () => {
      document.querySelectorAll('.card-reveal:not(.visible)').forEach((el) => observer.observe(el));
    };
    requestAnimationFrame(observeCards);

    // ── State ───────────────────────────────────────────────────
    const sectionNormal   = document.getElementById('section-normal')!;
    const sectionFiltered = document.getElementById('section-filtered')!;
    const normalCards     = document.querySelectorAll<HTMLElement>('[data-card-normal]');
    const filteredCards   = document.querySelectorAll<HTMLElement>('[data-card-filtered]');
    let activeYear  = 'all';
    let activeAutor = 'all';

    function applyFilters() {
      const hasAutor = activeAutor !== 'all';

      if (hasAutor) {
        // Mostrar vista filtrada con cards grandes
        sectionNormal.classList.add('hidden');
        sectionFiltered.classList.remove('hidden');
        filteredCards.forEach((c) => {
          const matchYear  = activeYear === 'all' || c.dataset.year === activeYear;
          const matchAutor = (c.dataset.autor ?? '').includes(activeAutor);
          c.style.display  = matchYear && matchAutor ? '' : 'none';
        });
        // Reanimar cards visibles
        requestAnimationFrame(observeCards);
      } else {
        // Mostrar vista normal
        sectionFiltered.classList.add('hidden');
        sectionNormal.classList.remove('hidden');
        normalCards.forEach((c) => {
          const matchYear = activeYear === 'all' || c.dataset.year === activeYear;
          c.style.display = matchYear ? '' : 'none';
        });
      }
    }

    // ── Filtro año (pills) ──────────────────────────────────────
    const yearBtns = document.querySelectorAll<HTMLButtonElement>('.year-btn');

    function setYearActive(btn: HTMLButtonElement) {
      yearBtns.forEach((b) => {
        const on = b === btn;
        b.classList.toggle('bg-navy', on);
        b.classList.toggle('text-white', on);
        b.classList.toggle('text-navy', !on);
        b.classList.toggle('border-black/12', !on);
        b.classList.toggle('border-transparent', on);
      });
    }

    yearBtns.forEach((btn) => {
      btn.addEventListener('click', () => {
        activeYear = btn.dataset.year!;
        setYearActive(btn);
        applyFilters();
      });
    });

    // ── Combobox autor ──────────────────────────────────────────
    const input    = document.getElementById('autor-input') as HTMLInputElement;
    const dropdown = document.getElementById('autor-dropdown') as HTMLUListElement;
    const clearBtn = document.getElementById('autor-clear') as HTMLButtonElement;
    const options  = document.querySelectorAll<HTMLLIElement>('.autor-option');
    let selectedAutor = '';

    function showDropdown() { dropdown.classList.remove('hidden'); }
    function hideDropdown() { dropdown.classList.add('hidden'); }

    function filterOptions(q: string) {
      const lower = q.toLowerCase();
      let visible = 0;
      options.forEach((opt) => {
        const match = opt.dataset.autorValue!.toLowerCase().includes(lower);
        opt.style.display = match ? '' : 'none';
        if (match) visible++;
      });
      visible > 0 ? showDropdown() : hideDropdown();
    }

    function selectAutor(name: string) {
      selectedAutor = name;
      activeAutor   = name;
      input.value   = name;
      clearBtn.classList.remove('hidden');
      clearBtn.classList.add('inline-flex');
      options.forEach((o) => {
        o.setAttribute('aria-selected', o.dataset.autorValue === name ? 'true' : 'false');
      });
      hideDropdown();
      applyFilters();
    }

    function clearAutor() {
      selectedAutor = '';
      activeAutor   = 'all';
      input.value   = '';
      clearBtn.classList.add('hidden');
      clearBtn.classList.remove('inline-flex');
      options.forEach((o) => { o.setAttribute('aria-selected', 'false'); o.style.display = ''; });
      hideDropdown();
      applyFilters();
    }

    input.addEventListener('focus', () => filterOptions(input.value));
    input.addEventListener('input', () => {
      if (selectedAutor && input.value !== selectedAutor) clearAutor();
      filterOptions(input.value);
    });

    options.forEach((opt) => {
      opt.addEventListener('mousedown', (e) => {
        e.preventDefault();
        selectAutor(opt.dataset.autorValue!);
      });
    });

    clearBtn.addEventListener('click', clearAutor);

    document.addEventListener('click', (e) => {
      if (!document.getElementById('autor-combobox')?.contains(e.target as Node)) {
        hideDropdown();
        if (!selectedAutor) input.value = '';
      }
    });

    input.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') { hideDropdown(); input.blur(); }
      if (e.key === 'Enter') {
        const first = [...options].find((o) => o.style.display !== 'none');
        if (first) selectAutor(first.dataset.autorValue!);
      }
    });
  }

  document.addEventListener('astro:page-load', initPublicaciones);
</script>
