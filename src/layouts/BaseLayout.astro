---
import { ClientRouter } from 'astro:transitions';
import SEO from '@/components/global/SEO.astro';
import Header from '@/components/global/Header.astro';
import Footer from '@/components/global/Footer.astro';
import Analytics from '@/components/global/Analytics.astro';
import MobileBottomBar from '@/components/interactive/MobileBottomBar.astro';
import '@/styles/global.css';

interface Props {
  title: string;
  description: string;
  canonical: string;
  ogImage?: string;
  type?: 'website' | 'article';
  schema?: unknown;
  noindex?: boolean;
}

const { title, description, canonical, ogImage, type, schema, noindex } = Astro.props;
---

<!doctype html>
<html lang="es-EC">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#1b88e2" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&family=Plus+Jakarta+Sans:wght@700;800&display=swap" rel="stylesheet" />
    <SEO title={title} description={description} canonical={canonical} ogImage={ogImage} type={type} schema={schema} noindex={noindex} />
    <ClientRouter />
    <Analytics />
  </head>
  <body>
    <a class="skip-link" href="#contenido-principal">Saltar al contenido principal</a>
    <Header />
    <main id="contenido-principal" tabindex="-1">
      <slot />
    </main>
    <Footer />
    <MobileBottomBar />
  </body>
</html>
